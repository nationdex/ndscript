{
	"name": "ndscript",
	"version": "0.1.0-alpha",
	"description": "ForgeScript extra for Project NationDex 2026. Run NDScript to perform runtime operations on NationDex data.",
	"homepage": "https://github.com/nationdex/ndscript#readme",
	"bugs": {
		"url": "https://github.com/nationdex/ndscript/issues"
	},
	"repository": {
		"type": "git",
		"url": "git+https://github.com/nationdex/ndscript.git"
	},
	"license": "MIT",
	"author": "astrod-ev",
	"type": "commonjs",
	"main": "dist/lib/index.js",
	"files": [
		"dist",
		"variables.json",
		"README.md",
		"LICENSE"
	],
	"scripts": {
		"build": "tsc && node scripts/copy-assets.js",
		"check": "biome check",
		"check:fix": "biome check --write",
		"typecheck": "tsc --noEmit"
	},
	"dependencies": {
		"@tryforge/forge.db": "github:tryforge/forgedb#main",
		"@tryforge/forgescript": "github:tryforge/forgescript#dev"
	},
	"devDependencies": {
		"@biomejs/biome": "^2.4.16",
		"@types/node": "^22.13.10",
		"typescript": "^6.0.3"
	}
}
